<Window x:Class="RhythmoSync.App.Tools.ShiftTimelineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Décaler la timeline"
        Background="{StaticResource BgDeep}"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <StackPanel Margin="18">

        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="Décale tous les blocs de dialogue dans le temps. Une valeur négative les avance, une valeur positive les retarde (le début reste borné à 0 s)."/>

        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"
                   Text="DÉCALAGE (SECONDES)" Margin="0,0,0,4"/>
        <TextBox x:Name="OffsetBox" Text="0"
                 Background="{StaticResource BgControl}" Foreground="{StaticResource TextPrimary}"
                 BorderBrush="{StaticResource BorderSubtle}" Padding="6,4" FontSize="13"
                 VerticalContentAlignment="Center"
                 PreviewTextInput="OnOffsetPreviewInput"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource AccentButton}" Content="Appliquer" Padding="14,6"
                    IsDefault="True" Click="OnApply"/>
            <Button Style="{StaticResource ToolButton}" Content="Annuler" Padding="14,6"
                    IsCancel="True"/>
        </StackPanel>

    </StackPanel>
</Window>
