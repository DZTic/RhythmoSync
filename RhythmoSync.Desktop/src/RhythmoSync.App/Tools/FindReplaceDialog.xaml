<Window x:Class="RhythmoSync.App.Tools.FindReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rechercher et remplacer"
        Background="{StaticResource BgDeep}"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <StackPanel Margin="18">

        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="Remplace le texte dans tous les blocs (texte et nom de personnage), sans tenir compte de la casse."/>

        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"
                   Text="RECHERCHER" Margin="0,0,0,4"/>
        <TextBox x:Name="FindBox"
                 Background="{StaticResource BgControl}" Foreground="{StaticResource TextPrimary}"
                 BorderBrush="{StaticResource BorderSubtle}" Padding="6,4" FontSize="13"
                 VerticalContentAlignment="Center"/>

        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"
                   Text="REMPLACER PAR" Margin="0,12,0,4"/>
        <TextBox x:Name="ReplaceBox"
                 Background="{StaticResource BgControl}" Foreground="{StaticResource TextPrimary}"
                 BorderBrush="{StaticResource BorderSubtle}" Padding="6,4" FontSize="13"
                 VerticalContentAlignment="Center"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource AccentButton}" Content="Remplacer tout" Padding="14,6"
                    IsDefault="True" Click="OnReplaceAll"/>
            <Button Style="{StaticResource ToolButton}" Content="Annuler" Padding="14,6"
                    IsCancel="True"/>
        </StackPanel>

    </StackPanel>
</Window>
