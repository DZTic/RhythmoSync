<Window x:Class="RhythmoSync.App.Tools.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Réglages"
        Background="{StaticResource BgDeep}"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Box" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgControl}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="18">

        <!-- ── Lecture ──────────────────────────────────────────────────────── -->
        <TextBlock Text="LECTURE" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

        <TextBlock Style="{StaticResource Lbl}" Text="DURÉE PAR DÉFAUT D'UN BLOC (S)"/>
        <TextBox x:Name="DurationBox" Style="{StaticResource Box}"/>

        <TextBlock Style="{StaticResource Lbl}" Text="DÉCALAGE DE SYNCHRO (MS)" Margin="0,12,0,4"/>
        <TextBox x:Name="SyncOffsetBox" Style="{StaticResource Box}"/>
        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"
                   Text="Compense la latence d'affichage : la tête de lecture des nouveaux blocs est décalée d'autant."/>

        <Rectangle Height="1" Fill="{StaticResource BorderSubtle}" Margin="0,16"/>

        <!-- ── Statistiques ─────────────────────────────────────────────────── -->
        <TextBlock Text="STATISTIQUES" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
        <Border Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                CornerRadius="6" Padding="12,8">
            <StackPanel>
                <DockPanel Margin="0,2">
                    <TextBlock Text="Blocs" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    <TextBlock x:Name="StatBlocks" DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontWeight="Bold" FontSize="12"/>
                </DockPanel>
                <DockPanel Margin="0,2">
                    <TextBlock Text="Durée cumulée" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    <TextBlock x:Name="StatDuration" DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontWeight="Bold" FontSize="12"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <Rectangle Height="1" Fill="{StaticResource BorderSubtle}" Margin="0,16"/>

        <!-- ── Affichage / projet ───────────────────────────────────────────── -->
        <TextBlock Text="AFFICHAGE &amp; PROJET" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
        <StackPanel Orientation="Horizontal">
            <Button x:Name="ResetViewButton" Style="{StaticResource ToolButton}" Content="⟲ Réinitialiser la vue"
                    Padding="12,6" Click="OnResetView"
                    ToolTip="Zoom, hauteur de piste et tête de lecture par défaut"/>
            <Button x:Name="ClearAllButton" Style="{StaticResource ToolButton}" Content="🧹 Tout effacer"
                    Padding="12,6" Margin="8,0,0,0" Click="OnClearAll"
                    Foreground="#f87171"
                    ToolTip="Supprimer tous les blocs de dialogue (annulable avec Ctrl+Z)"/>
        </StackPanel>

        <Rectangle Height="1" Fill="{StaticResource BorderSubtle}" Margin="0,16"/>

        <!-- ── Raccourcis clavier (liste de référence) ──────────────────────── -->
        <TextBlock Text="RACCOURCIS CLAVIER" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
        <Border Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                CornerRadius="6" Padding="12,6">
            <StackPanel x:Name="ShortcutList"/>
        </Border>

        <!-- ── Boutons ──────────────────────────────────────────────────────── -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource AccentButton}" Content="Enregistrer" Padding="14,6"
                    IsDefault="True" Click="OnSave"/>
            <Button Style="{StaticResource ToolButton}" Content="Fermer" Padding="14,6" IsCancel="True"/>
        </StackPanel>

    </StackPanel>
</Window>
