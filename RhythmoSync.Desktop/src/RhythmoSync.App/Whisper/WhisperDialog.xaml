<Window x:Class="RhythmoSync.App.Whisper.WhisperDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transcription IA — Whisper.cpp"
        Background="{StaticResource BgDeep}"
        Width="600" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgControl}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Badge personnage : bouton plat coloré, sans le chrome Windows -->
        <Style x:Key="BadgeButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="18">

        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="Transcription 100 % locale par whisper.cpp — l'audio ne quitte jamais votre machine. La première analyse peut prendre de 30 à 90 secondes selon le modèle et la durée de la vidéo."/>

        <!-- ── Configuration ───────────────────────────────────────────────── -->
        <StackPanel x:Name="ConfigPanel">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Modèle Whisper"/>
                <DockPanel Grid.Row="0" Grid.Column="1" Margin="0,4">
                    <ComboBox x:Name="ModelCombo" Width="170" FontSize="12" SelectionChanged="OnModelChanged"/>
                    <Button x:Name="DownloadModelButton" Style="{StaticResource ToolButton}" Margin="8,0,0,0"
                            Content="⬇ Télécharger" Click="OnDownloadModel"/>
                    <Button x:Name="DeleteModelButton" Style="{StaticResource ToolButton}" Margin="8,0,0,0"
                            Content="🗑 Supprimer" Click="OnDeleteModel"/>
                    <TextBlock x:Name="ModelStateText" Style="{StaticResource FieldLabel}" Margin="10,0,0,0"/>
                </DockPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Langue audio"/>
                <ComboBox x:Name="LanguageCombo" Grid.Row="1" Grid.Column="1" Width="170" FontSize="12"
                          HorizontalAlignment="Left" Margin="0,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Vidéo"/>
                <TextBlock x:Name="VideoFileText" Grid.Row="2" Grid.Column="1" Style="{StaticResource FieldLabel}"
                           Margin="0,4" TextTrimming="CharacterEllipsis"/>
            </Grid>

            <TextBlock x:Name="CliStateText" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- ── Progression ─────────────────────────────────────────────────── -->
        <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,14,0,0">
            <ProgressBar x:Name="TranscribeBar" Height="16" Minimum="0" Maximum="100"
                         Foreground="{StaticResource Accent}" Background="{StaticResource BgControl}"/>
            <DockPanel Margin="0,6,0,0">
                <TextBlock x:Name="ProgressStageText" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left"/>
                <TextBlock x:Name="ProgressMessageText" Style="{StaticResource FieldLabel}"
                           HorizontalAlignment="Right" Margin="0"/>
            </DockPanel>
        </StackPanel>

        <!-- ── Résultats ───────────────────────────────────────────────────── -->
        <StackPanel x:Name="ResultsPanel" Visibility="Collapsed" Margin="0,14,0,0">
            <TextBlock x:Name="SummaryText" Foreground="{StaticResource TextPrimary}" FontSize="12" Margin="0,0,0,10"/>

            <!-- Personnages associés aux pistes -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource BgPanel}" CornerRadius="6" Padding="8,6">
                    <DockPanel>
                        <Ellipse Width="11" Height="11" Fill="#8b5cf6" DockPanel.Dock="Left"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Style="{StaticResource MutedText}" Text="piste 1" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                        <TextBox x:Name="ProfileABox" Style="{StaticResource FieldBox}" Text="Personnage A"
                                 BorderThickness="0" Background="Transparent" TextChanged="OnProfileNameChanged"/>
                    </DockPanel>
                </Border>
                <Border Grid.Column="2" Background="{StaticResource BgPanel}" CornerRadius="6" Padding="8,6">
                    <DockPanel>
                        <Ellipse Width="11" Height="11" Fill="#10b981" DockPanel.Dock="Left"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Style="{StaticResource MutedText}" Text="piste 2" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                        <TextBox x:Name="ProfileBBox" Style="{StaticResource FieldBox}" Text="Personnage B"
                                 BorderThickness="0" Background="Transparent" TextChanged="OnProfileNameChanged"/>
                    </DockPanel>
                </Border>
            </Grid>

            <DockPanel Margin="0,0,0,6">
                <CheckBox x:Name="SelectAllCheck" Content="Tout sélectionner" IsChecked="True"
                          Foreground="{StaticResource TextPrimary}" FontSize="11" VerticalAlignment="Center"
                          Checked="OnSelectAllToggled" Unchecked="OnSelectAllToggled"/>
                <TextBlock Style="{StaticResource MutedText}" HorizontalAlignment="Right"
                           Text="Cliquez sur le badge coloré d'un segment pour changer de personnage."/>
            </DockPanel>

            <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="4">
                <ScrollViewer MaxHeight="270" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="SegmentsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="8,6">
                                    <DockPanel>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" DockPanel.Dock="Left"
                                                  VerticalAlignment="Top" Margin="0,2,8,0"/>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource BadgeButton}"
                                                Content="{Binding ProfileName}" Background="{Binding ProfileBrush}"
                                                Click="OnSegmentProfileClick" VerticalAlignment="Top" Margin="8,0,0,0"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextPrimary}"
                                                       FontSize="12" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding TimeLabel}" Foreground="{StaticResource TextMuted}"
                                                       FontSize="10" FontFamily="Consolas" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <TextBlock x:Name="ErrorText" Foreground="#f87171" FontSize="11" TextWrapping="Wrap"
                   Visibility="Collapsed" Margin="0,10,0,0"/>

        <!-- ── Boutons ─────────────────────────────────────────────────────── -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CancelTranscribeButton" Style="{StaticResource ToolButton}" Content="Annuler l'analyse"
                    Visibility="Collapsed" Click="OnCancelTranscribe" Padding="14,6"/>
            <Button x:Name="TranscribeButton" Style="{StaticResource AccentButton}" Content="🪄  Lancer l'analyse"
                    Click="OnTranscribe" Padding="14,6"/>
            <Button x:Name="ImportButton" Style="{StaticResource AccentButton}" Content="Importer"
                    Visibility="Collapsed" Click="OnImport" Padding="14,6"/>
            <Button x:Name="CloseButton" Style="{StaticResource ToolButton}" Content="Fermer"
                    Click="OnClose" Padding="14,6"/>
        </StackPanel>

    </StackPanel>
</Window>
