<Window x:Class="RhythmoSync.App.Export.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exporter la vidéo avec bande rythmo"
        Background="{StaticResource BgDeep}"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgControl}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FieldCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="18">

        <!-- ── Options ─────────────────────────────────────────────────────── -->
        <StackPanel x:Name="OptionsPanel">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Qualité (bitrate)"/>
                <DockPanel Grid.Row="0" Grid.Column="1" Margin="0,4">
                    <ComboBox x:Name="ResolutionCombo" Width="110" FontSize="12" SelectionChanged="OnResolutionChanged"/>
                    <TextBox x:Name="BitrateBox" Style="{StaticResource FieldBox}" Width="70" Margin="10,0,6,0" Text="8.0"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Mbps (la vidéo reste en 1920×1080 pour garder le texte net)"
                               TextWrapping="Wrap" FontSize="10"/>
                </DockPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Taille de la bande"/>
                <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,4">
                    <TextBlock x:Name="BandScaleLabel" Style="{StaticResource FieldLabel}" Text="×1.00" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                    <Slider x:Name="BandScaleSlider" Minimum="0.5" Maximum="2.0" Value="1.0"
                            TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                            ValueChanged="OnBandScaleChanged"/>
                </DockPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Encodeur"/>
                <ComboBox x:Name="EncoderCombo" Grid.Row="2" Grid.Column="1" Width="240" HorizontalAlignment="Left"
                          Margin="0,4" FontSize="12"/>
            </Grid>

            <CheckBox x:Name="LetterboxCheck" Style="{StaticResource FieldCheck}" IsChecked="True"
                      Content="Détecter et rogner automatiquement les bandes noires (letterbox)"/>
            <CheckBox x:Name="AudioCheck" Style="{StaticResource FieldCheck}" IsChecked="True"
                      Content="Inclure l'audio de la vidéo originale"/>
            <CheckBox x:Name="RangeCheck" Style="{StaticResource FieldCheck}"
                      Content="Exporter une plage seulement" Checked="OnRangeToggled" Unchecked="OnRangeToggled"/>

            <StackPanel x:Name="RangePanel" Orientation="Horizontal" Margin="24,6,0,0" IsEnabled="False">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Début (s)"/>
                <TextBox x:Name="RangeStartBox" Style="{StaticResource FieldBox}" Width="80" Text="0"/>
                <TextBlock Style="{StaticResource FieldLabel}" Text="Fin (s)" Margin="14,0,10,0"/>
                <TextBox x:Name="RangeEndBox" Style="{StaticResource FieldBox}" Width="80"/>
            </StackPanel>
        </StackPanel>

        <!-- ── Progression ─────────────────────────────────────────────────── -->
        <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,14,0,0">
            <ProgressBar x:Name="ExportProgressBar" Height="16" Minimum="0" Maximum="100"
                         Foreground="{StaticResource Accent}" Background="{StaticResource BgControl}"/>
            <DockPanel Margin="0,6,0,0">
                <TextBlock x:Name="ProgressLeft" Style="{StaticResource FieldLabel}" Text="Préparation…" DockPanel.Dock="Left"/>
                <TextBlock x:Name="ProgressRight" Style="{StaticResource FieldLabel}" HorizontalAlignment="Right" Margin="0"/>
            </DockPanel>
        </StackPanel>

        <!-- ── Boutons ─────────────────────────────────────────────────────── -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CancelButton" Style="{StaticResource ToolButton}" Content="Annuler l'export"
                    Visibility="Collapsed" Click="OnCancelExport" Padding="14,6"/>
            <Button x:Name="ExportButton" Style="{StaticResource AccentButton}" Content="🎞  Exporter…"
                    Click="OnStartExport" Padding="14,6"/>
            <Button x:Name="CloseButton" Style="{StaticResource ToolButton}" Content="Fermer"
                    Click="OnClose" Padding="14,6"/>
        </StackPanel>

    </StackPanel>
</Window>
