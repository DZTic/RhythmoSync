<Window x:Class="RhythmoSync.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:RhythmoSync.App.Controls"
        Title="RhythmoSync Studio"
        Background="{StaticResource BgDeep}"
        WindowStartupLocation="CenterScreen"
        Width="1400" Height="900"
        WindowState="Maximized"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <DockPanel>

        <!-- ── Barre d'outils ─────────────────────────────────────────────── -->
        <Border x:Name="ToolbarBorder" DockPanel.Dock="Top" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="8,6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="🎙️ RhythmoSync" Foreground="{StaticResource TextPrimary}"
                               FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="2,0,14,0"/>
                    <Button x:Name="NewButton" Style="{StaticResource ToolButton}" Content="Nouveau" Click="OnNewProject"/>
                    <Button x:Name="OpenButton" Style="{StaticResource ToolButton}" Content="Ouvrir…" Click="OnOpenProject"/>
                    <Button x:Name="SaveButton" Style="{StaticResource ToolButton}" Content="Enregistrer" Click="OnSaveProject"/>
                    <Rectangle Width="1" Fill="{StaticResource BorderSubtle}" Margin="8,2"/>
                    <Button x:Name="ImportVideoButton" Style="{StaticResource AccentButton}" Content="🎬 Importer une vidéo" Click="OnImportVideo"/>
                    <Button x:Name="AddBlockButton" Style="{StaticResource ToolButton}" Content="＋ Bloc" Click="OnAddBlock"
                            ToolTip="Ajouter un bloc à la position de lecture (double-clic sur la bande aussi)"/>
                    <Button x:Name="ExportVideoButton" Style="{StaticResource ToolButton}" Content="🎞 Exporter" Click="OnExportVideo"
                            ToolTip="Exporter la vidéo avec la bande rythmo incrustée (MP4)"/>
                    <Button x:Name="ExportTextButton" Style="{StaticResource ToolButton}" Content="📄 Texte…" Click="OnExportText"
                            ToolTip="Exporter les dialogues en sous-titres ou transcript (SRT, VTT, TXT, CSV)"/>
                    <Button x:Name="ImportSubtitleButton" Style="{StaticResource ToolButton}" Content="📥 Sous-titres…" Click="OnImportSubtitles"
                            ToolTip="Importer des sous-titres (.srt, .vtt) comme blocs de dialogue"/>
                    <Button x:Name="WhisperButton" Style="{StaticResource ToolButton}" Content="🪄 Whisper" Click="OnWhisper"
                            ToolTip="Transcrire l'audio en blocs de dialogue (whisper.cpp, 100 % local)"/>
                    <Rectangle Width="1" Fill="{StaticResource BorderSubtle}" Margin="8,2"/>
                    <Button x:Name="ShiftButton" Style="{StaticResource ToolButton}" Content="↔ Décaler" Click="OnShiftTimeline"
                            ToolTip="Décaler tous les blocs dans le temps"/>
                    <Button x:Name="FindReplaceButton" Style="{StaticResource ToolButton}" Content="🔍 Remplacer" Click="OnFindReplace"
                            ToolTip="Rechercher et remplacer dans les textes et noms de personnages (Ctrl+H)"/>
                    <Button x:Name="BlockEditorButton" Style="{StaticResource ToolButton}" Content="✏ Édition" Click="OnToggleBlockEditor"
                            ToolTip="Afficher / masquer le panneau d'édition du bloc sélectionné"/>
                    <Button x:Name="HistoryButton" Style="{StaticResource ToolButton}" Content="🕘 Historique" Click="OnToggleHistory"
                            ToolTip="Afficher / masquer le panneau d'historique (annuler / rétablir)"/>
                    <Button x:Name="SettingsButton" Style="{StaticResource ToolButton}" Content="⚙ Réglages" Click="OnSettings"
                            ToolTip="Réglages (durée par défaut, synchro), statistiques, réinitialiser la vue, tout effacer"/>
                    <Button x:Name="PresentationButton" Style="{StaticResource ToolButton}" Content="⛶ Présentation" Click="OnPresentation"
                            ToolTip="Mode Présentation / Doublage plein écran (F11 ; Échap pour quitter)"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Style="{StaticResource MutedText}" Text="Zoom"/>
                    <Slider x:Name="ZoomSlider" Width="110" Minimum="40" Maximum="600" Value="200"
                            VerticalAlignment="Center" Margin="6,0,10,0" ValueChanged="OnZoomChanged"/>
                    <CheckBox x:Name="SnapCheck" Content="Snap" IsChecked="True" Checked="OnSnapChanged" Unchecked="OnSnapChanged"
                              Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="11"/>
                    <TextBlock Style="{StaticResource MutedText}" Text="Pistes"/>
                    <Button x:Name="LaneMinusButton" Style="{StaticResource ToolButton}" Content="−" Padding="7,2" Margin="6,0,0,0" Click="OnLaneMinus"/>
                    <TextBlock x:Name="LaneCountText" Text="3" Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" Margin="7,0" FontSize="12" FontWeight="Bold"/>
                    <Button x:Name="LanePlusButton" Style="{StaticResource ToolButton}" Content="＋" Padding="7,2" Margin="0,0,12,0" Click="OnLanePlus"/>
                    <TextBlock Style="{StaticResource MutedText}" Text="Hauteur"/>
                    <Slider x:Name="LaneHeightSlider" Width="90" Minimum="40" Maximum="200" Value="80"
                            VerticalAlignment="Center" Margin="6,0,12,0" ValueChanged="OnLaneHeightChanged"
                            ToolTip="Échelle verticale : hauteur des pistes (px)"/>
                    <TextBlock Style="{StaticResource MutedText}" Text="FPS"/>
                    <ComboBox x:Name="FpsCombo" Width="64" Margin="6,0,0,0" VerticalAlignment="Center"
                              SelectionChanged="OnFpsChanged" FontSize="11"/>
                </StackPanel>
                <Border/>
            </DockPanel>
        </Border>

        <!-- ── Barre d'état ───────────────────────────────────────────────── -->
        <Border x:Name="StatusBorder" DockPanel.Dock="Bottom" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0" Padding="10,3">
            <DockPanel>
                <TextBlock x:Name="StatusLeft" Style="{StaticResource MutedText}" Text="Prêt." DockPanel.Dock="Left"/>
                <Button x:Name="ProxyCacheButton" DockPanel.Dock="Right" Style="{StaticResource ToolButton}"
                        FontSize="11" Padding="6,1" Margin="10,0,0,0" Visibility="Collapsed"
                        Click="OnClearProxyCache"
                        ToolTip="Supprimer les copies de lecture (proxys) — elles seront régénérées au besoin"/>
                <TextBlock x:Name="StatusRight" Style="{StaticResource MutedText}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                <Border/>
            </DockPanel>
        </Border>

        <!-- ── Panneau d'historique (port du HistoryPanel web) ──────────────── -->
        <Border x:Name="HistoryBorder" DockPanel.Dock="Right" Width="260"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,0,0"
                Visibility="Collapsed">
            <controls:HistoryPanel x:Name="History"/>
        </Border>

        <!-- ── Panneau d'édition du bloc (port de l'EditorSidebar web) ──────── -->
        <Border x:Name="BlockEditorBorder" DockPanel.Dock="Right" Width="300"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,0,0">
            <controls:BlockEditorPanel x:Name="BlockEditor"/>
        </Border>

        <!-- ── Zone centrale ──────────────────────────────────────────────── -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Vidéo + mixeur audio -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="Black">
                <Grid>
                    <MediaElement x:Name="Media"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Manual"
                                  ScrubbingEnabled="True"
                                  Stretch="Uniform"
                                  MediaOpened="OnMediaOpened"
                                  MediaEnded="OnMediaEnded"
                                  MediaFailed="OnMediaFailed"/>
                    <TextBlock x:Name="VideoPlaceholder"
                               Text="Importez une vidéo pour commencer  (Ctrl+I)"
                               Foreground="{StaticResource TextMuted}" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <!-- Encodage du proxy (non bloquant : bande et waveform restent utilisables) -->
                    <StackPanel x:Name="ProxyPanel" Visibility="Collapsed" Width="360"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="ProxyText" Text="Préparation de la copie de lecture…"
                                   Foreground="{StaticResource TextPrimary}" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,0,0,4" TextAlignment="Center"/>
                        <TextBlock Text="Ce format n'est pas lu par Windows — vous pouvez déjà éditer la bande."
                                   Foreground="{StaticResource TextMuted}" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,0,0,10" TextAlignment="Center" TextWrapping="Wrap"/>
                        <ProgressBar x:Name="ProxyBar" Height="8" Minimum="0" Maximum="100"/>
                        <Button x:Name="ProxyCancelButton" Style="{StaticResource ToolButton}" Content="Annuler"
                                HorizontalAlignment="Center" Margin="0,12,0,0" Click="OnProxyCancel"/>
                    </StackPanel>

                    <!-- Bandeau du Mode Présentation / Doublage (overlay, masqué hors présentation) -->
                    <Border x:Name="PresentationHint" Visibility="Collapsed"
                            VerticalAlignment="Top" Background="#CC000000" Padding="14,8">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource ToolButton}" Content="⤫ Quitter"
                                    Click="OnExitPresentation"/>
                            <TextBlock Text="🎬 Mode Présentation" Foreground="White" FontWeight="Bold"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="F11 / Échap pour quitter" Foreground="#80FFFFFF"
                                       FontFamily="Consolas" FontSize="11" Margin="14,0,0,0" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Mixeur audio multi-pistes (repliable) -->
            <Border x:Name="MixerPanel" Grid.Column="1" Width="240"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <controls:AudioMixerPanel x:Name="Mixer"/>
            </Border>
            </Grid>

            <!-- Transport -->
            <Border Grid.Row="1" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1" Padding="10,6">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button x:Name="PlayButton" Style="{StaticResource AccentButton}" Content="▶  Lecture"
                                Width="110" Click="OnPlayPause"/>
                        <TextBlock x:Name="TimecodeText" Text="00:00:00:00" Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="16,0,6,0"/>
                        <TextBlock x:Name="DurationText" Text="/ 00:00:00:00" Foreground="{StaticResource TextMuted}"
                                   FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <TextBlock Style="{StaticResource MutedText}" Text="Vitesse"/>
                        <ComboBox x:Name="RateCombo" Width="64" Margin="6,0,14,0" VerticalAlignment="Center"
                                  SelectionChanged="OnRateChanged" FontSize="11"/>
                        <TextBlock Style="{StaticResource MutedText}" Text="Volume"/>
                        <Slider x:Name="VolumeSlider" Width="90" Minimum="0" Maximum="1" Value="0.9"
                                VerticalAlignment="Center" Margin="6,0,10,0" ValueChanged="OnVolumeChanged"/>
                        <Button x:Name="MixerButton" Style="{StaticResource ToolButton}" Content="🎚 Mixeur"
                                Click="OnToggleMixer"
                                ToolTip="Afficher / masquer le mixeur audio multi-pistes"/>
                    </StackPanel>
                    <Border/>
                </DockPanel>
            </Border>

            <!-- Bande rythmo + zone d'édition de texte superposée -->
            <Grid Grid.Row="2">
                <controls:RhythmoBandControl x:Name="Band"/>
                <Canvas>
                    <TextBox x:Name="EditBox"
                             Visibility="Collapsed"
                             Background="{StaticResource BgPanel}"
                             Foreground="White"
                             FontFamily="Consolas" FontWeight="Bold"
                             TextAlignment="Center" VerticalContentAlignment="Center"
                             BorderBrush="{StaticResource Accent}" BorderThickness="1"
                             PreviewKeyDown="OnEditBoxKeyDown"
                             LostFocus="OnEditBoxLostFocus"/>
                </Canvas>
            </Grid>

            <!-- Forme d'onde -->
            <controls:WaveformControl x:Name="Wave" Grid.Row="3" Height="70"/>
        </Grid>

    </DockPanel>
</Window>
